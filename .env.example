# Copy to .env.local for local development

# MongoDB Atlas connection string (free tier: https://cloud.mongodb.com)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kubeforge?retryWrites=true&w=majority"

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret"

# Required for NextAuth v5 — set to your deployment URL (or http://localhost:3000 locally)
AUTH_URL="https://your-domain.vercel.app"
